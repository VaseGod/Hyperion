# =============================================================================
# Dark Factory v2 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your local setup.
# =============================================================================

# ---------------------------------------------------------------------------
# Local LLM Inference Endpoint (OpenAI-compatible API)
# ---------------------------------------------------------------------------
# Base URL for the local inference server (e.g., vLLM, llama.cpp, Ollama)
LLM_API_BASE=http://localhost:8000/v1

# Model identifier as registered on the inference server
LLM_MODEL_NAME=qwen2.5-72b-instruct

# API key (often "EMPTY" or "none" for local servers)
LLM_API_KEY=EMPTY

# Maximum tokens the model can generate per response
LLM_MAX_TOKENS=4096

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# ---------------------------------------------------------------------------
# Parchi Relay Daemon
# ---------------------------------------------------------------------------
# URL where the Parchi relay daemon is listening
PARCHI_RELAY_URL=http://localhost:9222

# Timeout in seconds for browser operations
PARCHI_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# WebArena-Infinity Evaluation
# ---------------------------------------------------------------------------
# Base URL for the WebArena evaluation environment
WEBARENA_BASE_URL=http://localhost:4399

# ---------------------------------------------------------------------------
# Agent Configuration
# ---------------------------------------------------------------------------
# Directory containing agentskills.io skill files
SKILLS_DIRECTORY=skills

# Path for persistent agent memory storage
MEMORY_STORE_PATH=data/agent_memory.json

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
